{
  "name": "react-native-bdk-sdk",
  "description": "React Native language bindings for the Bitcoin Development Kit",
  "source": "./src/index.tsx",
  "main": "./lib/commonjs/index.js",
  "module": "./lib/module/index.js",
  "types": "./lib/typescript/module/src/index.d.ts",
  "exports": {
    "./app.plugin.js": "./app.plugin.js",
    ".": {
      "import": {
        "types": "./lib/typescript/module/src/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/src/index.d.ts",
        "default": "./lib/commonjs/index.js"
      }
    }
  },
  "keywords": [
    "bitcoin",
    "bdk",
    "react-native",
    "expo",
    "ios",
    "android"
  ],
  "license": "MIT",
  "packageManager": "pnpm@10.6.2",
  "workspaces": [
    "expo-example"
  ],
  "scripts": {
    "ubrn:ios": "ubrn build ios --release --config ubrn.config.yaml --and-generate",
    "ubrn:android": "ubrn build android --release --config ubrn.config.yaml --and-generate",
    "postinstall": "node scripts/postinstall.js",
    "prepare": "bob build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Psycarlo/react-native-bdk-sdk.git"
  },
  "author": {
    "name": "Psycarlo",
    "url": "https://psycarlo.com"
  },
  "bugs": {
    "url": "https://github.com/Psycarlo/react-native-bdk-sdk/issues"
  },
  "homepage": "https://github.com/Psycarlo/react-native-bdk-sdk#readme",
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "checksums": {
    "android": "",
    "ios": ""
  },
  "dependencies": {
    "uniffi-bindgen-react-native": "0.30.0-1"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "@expo/config-plugins": "^55.0.6",
    "@react-native-community/cli": "^20.1.2",
    "@types/react": "^19.2.14",
    "expo-module-scripts": "^55.0.2",
    "react": "^19.2.4",
    "react-native": "^0.84.1",
    "react-native-builder-bob": "^0.40.18",
    "typescript": "^5.9.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "rust_modules/**",
    "targets": [
      "codegen",
      [
        "commonjs",
        {
          "esm": true
        }
      ],
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.build.json"
        }
      ]
    ]
  },
  "codegenConfig": {
    "name": "RNBdkReactNativeSpec",
    "type": "all",
    "jsSrcsDir": "src",
    "outputDir": {
      "ios": "ios/generated",
      "android": "android/generated"
    },
    "android": {
      "javaPackageName": "com.reactnativebdksdk"
    },
    "includesGeneratedCode": false
  },
  "create-react-native-library": {
    "type": "turbo-module",
    "languages": "cpp",
    "version": "0.49.0"
  }
}
